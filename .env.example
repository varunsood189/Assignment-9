# Assignment 9 — copy to .env and fill in keys
# Used by llm_gatewayV9 (reads parent .env) and S9SharedCode/code

# ── LLM providers (at least one required for gateway) ────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional failover providers
GROQ_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
OPEN_ROUTER_API_KEY=
GITHUB_ACCESS_TOKEN=

# Provider order (comma-separated)
LLM_ORDER=gemini
ROUTER_ORDER=gemini

# ── Researcher / MCP tools ───────────────────────────────────────────────
TAVILY_API_KEY=

# ── Gateway ──────────────────────────────────────────────────────────────
GATEWAY_V9_PORT=8109
LLM_GATEWAY_V9_URL=http://localhost:8109
